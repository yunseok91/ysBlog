# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# OpenAI(GPT) API 키 — https://platform.openai.com/api-keys 에서 발급 (따옴표 없이)
OPENAI_API_KEY=

# 사용할 모델 (gpt-4o-mini 권장, 더 좋은 품질은 gpt-4o)
OPENAI_MODEL=gpt-4o-mini

# 네이버 블로그 아이디 (글쓰기 페이지 주소에 사용)
NAVER_BLOG_ID=ys_note91
